#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 1/2 Verificando tipado de TypeScript en el proyecto..."

# Ejecuta el script de tu package.json (tsc --noEmit)
if ! npm run check-types; then
  echo "❌ Error de tipado en TypeScript. Corrige los errores antes de hacer el commit."
  exit 1
fi

echo "✅ Tipado correcto."
echo "🔍 2/2 Ejecutando Linter y Prettier en los archivos modificados..."

if npx lint-staged; then
  echo "✅ ¡Todo perfecto! Commit exitoso."
  exit 0
else
  echo "❌ El Linter encontró problemas. Revísalos antes de hacer el commit."
  exit 1
fi